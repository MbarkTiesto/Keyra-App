{
  "name": "keyra-authenticator",
  "productName": "Keyra Authenticator",
  "version": "1.0.0",
  "description": "A secure Desktop Authenticator Application",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "tsc -p tsconfig.renderer.json && copy src\\renderer\\index.html dist\\renderer\\renderer\\index.html && copy src\\renderer\\capture.html dist\\renderer\\renderer\\capture.html && xcopy /E /Y /I src\\renderer\\css dist\\renderer\\renderer\\css && xcopy /E /Y /I src\\renderer\\fonts dist\\renderer\\renderer\\fonts && xcopy /E /Y /I src\\renderer\\js\\vendor dist\\renderer\\renderer\\js\\vendor && xcopy /E /Y /I src\\renderer\\assets dist\\renderer\\renderer\\assets",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --windows --publish never",
    "release": "npm run build && electron-builder --windows --publish always",
    "dist:win64": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.keyra.authenticator",
    "productName": "Keyra Authenticator",
    "directories": {
      "output": "dist/build"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Keyra Authenticator"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "MbarkT3STO",
        "repo": "Keyra-App"
      }
    ],
    "extraResources": [
      ".env"
    ]
  },
  "keywords": [],
  "author": "Keyra",
  "license": "ISC",
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "jsqr": "^1.4.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "nodemailer": "^8.0.2"
  }
}