{
  "name": "keyra-authenticator",
  "productName": "Keyra Authenticator",
  "version": "1.4.0",
  "description": "A secure Desktop Authenticator Application",
  "homepage": "https://keyraauth.netlify.app/",
  "author": "MBVRK <me@MBVRK.onmicrosoft.com>",
  "main": "dist/main/main.js",
  "scripts": {
    "build:html": "node scripts/build-html.js",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "npm run build:html && tsc -p tsconfig.renderer.json && copy src\\renderer\\index.html dist\\renderer\\renderer\\index.html && copy src\\renderer\\capture.html dist\\renderer\\renderer\\capture.html && xcopy /E /Y /I src\\renderer\\css dist\\renderer\\renderer\\css && xcopy /E /Y /I src\\renderer\\fonts dist\\renderer\\renderer\\fonts && xcopy /E /Y /I src\\renderer\\webfonts dist\\renderer\\renderer\\webfonts && xcopy /E /Y /I src\\renderer\\assets dist\\renderer\\renderer\\assets",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "cbs": "cls && npm run build && electron .",
    "dist": "npm run build && electron-builder --windows --publish never",
    "release": "npm run build && electron-builder --windows --publish always",
    "dist:win64": "electron-builder --win --x64",
    "dist:mac-intel": "electron-builder --mac --x64",
    "dist:mac-arm": "electron-builder --mac --arm64",
    "dist:linux-x64": "electron-builder --linux --x64",
    "dist:linux-arm64": "electron-builder --linux --arm64"
  },
  "build": {
    "appId": "com.keyra.authenticator",
    "productName": "Keyra Authenticator",
    "icon": "assets/icon.png",
    "directories": {
      "output": "dist/build"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": "deb"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Keyra Authenticator"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "MbarkT3STO",
        "repo": "Keyra-App"
      }
    ],
    "extraResources": [
      ".env"
    ]
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "jsqr": "^1.4.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "nodemailer": "^8.0.2",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.6"
  }
}