{
  "name": "keyra-authenticator-android",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cls && vite",
    "dev:netlify": "netlify dev",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:html": "node scripts/build-html.cjs",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run build && npx cap sync && npx cap open android",
    "cap:run": "npm run build && npx cap sync && npx cap run android --livereload --external",
    "apk": "node scripts/build-html.cjs && npm run build && npx cap sync android && cd android && gradlew assembleDebug"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^7.2.0",
    "@capacitor-community/privacy-screen": "^5.2.1",
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/browser": "^6.0.6",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "buffer": "^6.0.3",
    "jsqr": "^1.4.0",
    "otplib": "^13.3.0",
    "uuid": "^11.0.0",
    "vite-plugin-node-polyfills": "^0.25.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@netlify/functions": "^5.1.5",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0"
  }
}
