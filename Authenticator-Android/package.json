    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "buffer": "^6.0.3",
    "jsqr": "^1.4.0",
    "otplib": "^13.3.0",
    "uuid": "^11.0.0",
    "vite-plugin-node-polyfills": "^0.25.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0"
  }
}
