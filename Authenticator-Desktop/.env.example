# Keyra Authenticator - Environment Configuration
# Copy this file to .env and fill in your details

# --- SMTP Mail Server (Gmail / Custom) ---
# For Gmail: Use smtp.gmail.com | Port: 587
# You MUST use an "App Password" (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM_NAME=Keyra Authenticator
